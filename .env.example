# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# github-task-controller API Base URL
API_BASE_URL=http://localhost:8080

# 認証用セッションCookie値（github-task-controllerにログイン後、auth-session Cookieの値を設定）
AUTH_COOKIE=your_auth_session_cookie_here

# デフォルトユーザーID（プロジェクト操作に使用）
DEFAULT_USER_ID=your_user_id_here
